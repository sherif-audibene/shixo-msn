#!/bin/sh
### BEGIN INIT INFO
# Provides:          shixo-msn
# Required-Start:    $network $remote_fs
# Required-Stop:     $network $remote_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: shixo-msn sync server
### END INIT INFO

NAME=shixo-msn
DIR=/opt/shixo-msn
RUNUSER=jenkins
PIDFILE=/var/run/$NAME.pid
LOG=/var/log/$NAME.log
CMD="$DIR/clipsrv -config /etc/clip/config.toml"

is_alive() {
  # PID file alone lies — OS reuses PIDs. Validate the proc owns *our* binary.
  [ -f "$PIDFILE" ] || return 1
  pid=$(cat "$PIDFILE" 2>/dev/null) || return 1
  [ -n "$pid" ] && [ -r "/proc/$pid/comm" ] && [ "$(cat /proc/$pid/comm)" = "clipsrv" ]
}

start() {
  if is_alive; then
    echo "$NAME already running (pid $(cat "$PIDFILE"))"
    return 0
  fi
  rm -f "$PIDFILE"
  echo "Starting $NAME"
  start-stop-daemon --start --quiet --background --make-pidfile \
    --pidfile "$PIDFILE" --chuid "$RUNUSER" --chdir "$DIR" \
    --startas /bin/sh -- -c "exec $CMD >> $LOG 2>&1"
}

stop() {
  echo "Stopping $NAME"
  start-stop-daemon --stop --quiet --pidfile "$PIDFILE" --retry TERM/10/KILL/5 || true
  rm -f "$PIDFILE"
}

case "$1" in
  start)   start ;;
  stop)    stop ;;
  restart) stop; sleep 1; start ;;
  status)
    if is_alive && curl -fsS --max-time 3 http://127.0.0.1:6303/api/health >/dev/null; then
      echo "$NAME running (pid $(cat "$PIDFILE"))"
    else
      echo "$NAME not running"
      exit 3
    fi
    ;;
  *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
